# pi-server HTTP base URL (no trailing slash required)
VITE_PI_SERVER_URL=http://127.0.0.1:3141

# Optional. Intended only for a trusted local/private deployment.
# Any VITE_ value is included in the browser bundle: never use this for a
# publicly exposed server. Prefer a same-origin reverse proxy for that setup.
# VITE_PI_SERVER_AUTH_TOKEN=